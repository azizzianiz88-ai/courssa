// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  name      String?
  phone     String   @unique
  email     String?  @unique
  role      Role     @default(CLIENT)
  photoUrl  String?
  rating    Float    @default(5.0) // For drivers specifically
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ordersAsClient Order[] @relation("ClientOrders")
  ordersAsDriver Order[] @relation("DriverOrders")
  offers         Offer[]
  vehicles       Vehicle[] @relation("DriverVehicles")
}

model Vehicle {
  id          String        @id @default(cuid())
  type        String        // Camionnette, Fourgon, Petit Camion, etc.
  capacity    Float?        // in tonnes
  status      VehicleStatus @default(AVAILABLE) // available, in-service, broken
  plateNumber String?
  photoUrl    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  ownerId     String
  owner       User          @relation("DriverVehicles", fields: [ownerId], references: [id], onDelete: Cascade)
}

model Order {
  id            String      @id @default(cuid())
  title         String
  pickUp        String
  dropOff       String
  stop          String?
  type          String
  urgency       String
  description      String
  hasInvoice       Boolean     @default(false)
  needWorkers      Boolean     @default(false)
  workersPayer     String?
  photoAttached    Boolean     @default(false)
  requestedVehicle String?     // Targeted vehicle mapping
  status           OrderStatus @default(PENDING)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  clientId      String
  client        User        @relation("ClientOrders", fields: [clientId], references: [id])
  
  driverId      String?
  driver        User?       @relation("DriverOrders", fields: [driverId], references: [id])

  offers        Offer[]
}

model Offer {
  id        String   @id @default(cuid())
  price     Float
  vehicle   String
  message   String?
  status    OfferStatus @default(PENDING)
  createdAt DateTime @default(now())

  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  driverId  String
  driver    User     @relation(fields: [driverId], references: [id])
}

enum Role {
  CLIENT
  DRIVER
  ADMIN
}

enum OrderStatus {
  PENDING
  NEGOTIATING
  WAITING
  LOADING
  IN_TRANSIT
  UNLOADING
  COMPLETED
  CANCELLED
}

enum OfferStatus {
  PENDING
  NEGOTIATING
  ACCEPTED
  REJECTED
}

enum VehicleStatus {
  AVAILABLE
  IN_SERVICE
  MAINTENANCE
}
